{
  "name": "centryx-backend",
  "version": "1.0.0",
  "description": "Backend API para Centryx MDM (NestJS + TimescaleDB + Redis + Supabase)",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\"",
