<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050A14"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:background="@drawable/bg_glass_card"
        android:padding="28dp"
        android:elevation="12dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Asistente de Permisos de Supervisión DPC"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Otorgue los permisos obligatorios para conectar este teléfono en vivo con la plataforma."
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnGrantUsageStats"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="1. Permiso Uso de Apps (Usage Stats)"
            android:textColor="#2DD4BF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_navy_button"
            android:layout_marginBottom="14dp" />

        <Button
            android:id="@+id/btnGrantDeviceAdmin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="2. Permiso Administrador DPC (Bloqueos)"
            android:textColor="#2DD4BF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_navy_button"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnCompleteEnrollment"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="3. Conectar a Supabase &amp; Activar"
            android:textColor="#050A14"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_gradient_button" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</RelativeLayout>
