<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#050A14">

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Concesión de Permisos de Supervisión DPC"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnGrantUsageStats"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="1. Conceder Permiso Uso de Aplicaciones"
        android:textColor="#FFFFFF"
        android:backgroundTint="#0D1B2E"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnGrantDeviceAdmin"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="2. Conceder Permiso Administrador DPC"
        android:textColor="#FFFFFF"
        android:backgroundTint="#0D1B2E"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnCompleteEnrollment"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="3. Completar Enrolamiento y Activar Supervisión"
        android:textColor="#050A14"
        android:textStyle="bold"
        android:backgroundTint="#2DD4BF" />

</LinearLayout>
